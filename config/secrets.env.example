# Polygon.io API (Data Source - Historical Options Chains)
# Sign up: https://polygon.io/
# Get API key: Dashboard → API Keys
POLYGON_API_KEY=your_polygon_api_key_here
POLYGON_TIER=professional

# Fidelity API (Order Execution - Phase 3)
# Only needed when you're ready for live trading
# Get credentials from: https://developer.fidelity.com/
FIDELITY_ACCOUNT_NUMBER=your_account_number_here
FIDELITY_OAUTH_TOKEN=will_auto_refresh
